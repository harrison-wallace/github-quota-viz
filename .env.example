# GitHub Usage Dashboard - Optional Environment Variables
# 
# Profiles are now managed via the GUI, but you can pre-populate defaults
# for Docker deployments or local development (optional)

# Pre-load default profiles (JSON array format)
# Each profile needs: name, username, and base64-encoded token
# Profiles added via GUI take precedence and override these
# Example: [{"name":"Work","username":"john","token":"Z2l0aHViX3BhdF8xMjM0NTY3OA=="}]
REACT_APP_DEFAULT_PROFILES=

# Default Actions Quota (Free tier: 2000 minutes/month) - UI reference only
REACT_APP_ACTIONS_QUOTA=2000

# Default Premium Requests Quota (Copilot Pro: unlimited, but set soft limit for visualization)
REACT_APP_PREMIUM_REQUESTS_QUOTA=1000
